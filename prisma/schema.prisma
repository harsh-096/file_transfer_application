datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Transfer {
  id        String   @id @default(uuid())
  fileName  String
  fileKey   String // The actual path/name in Backblaze B2
  fileSize  Int
  shortCode String   @unique // The shortened URL identifier
  expiresAt DateTime
  createdAt DateTime @default(now())
}
