datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Transfer {
  id        String         @id @default(uuid())
  title     String?
  message   String?
  shortCode String         @unique // The shortened URL identifier
  expiresAt DateTime
  createdAt DateTime       @default(now())
  files     TransferFile[]
}

model TransferFile {
  id         String   @id @default(uuid())
  transferId String
  path       String
  name       String
  key        String
  size       Int
  type       String
  createdAt  DateTime @default(now())

  transfer Transfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

  @@index([transferId])
}
